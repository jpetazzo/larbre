cluster:
  controllerManager:
    extraArgs:
      node-cidr-mask-size-ipv4: 24
      node-cidr-mask-size-ipv6: 120
  network:
    cni:
      name: none
    podSubnets:
      - fd44::/112
      - 10.44.0.0/16
    serviceSubnets:
      - fd55::/112
      - 10.55.0.0/16
  proxy:
    disabled: true
machine:
  features:
    kubePrism:
      enabled: true
      port: 7445
